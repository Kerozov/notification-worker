# =============================================================================
# TENANT TEMPLATE — copy block per client into .env.local + Vercel, then seed
# =============================================================================
#
# 1. Replace CLIENT_ID (UPPER_SNAKE, no spaces) — becomes slug in DB:
#      TENANT_MY_CLIENT_KEY  →  slug: my-client
#
# 2. Generate a key (or run: bun run tenant:new CLIENT_ID "Display Name")
#
# 3. Paste block below into .env.local AND Vercel env
#
# 4. bun run seed   (writes/updates tenants table in Supabase)
#
# 5. On the client's site (backend only):
#      NOTIFICATION_WORKER_URL=https://notification-worker-phi.vercel.app
#      NOTIFICATION_WORKER_API_KEY=<same value as TENANT_*_KEY below>
#
# Email only: skip SMS_SENDER and NOTIFIER_KEY lines.
# SMS: NOTIFIER_KEY = API token from notifierbg.com profile (not the worker key).
#
# =============================================================================

# --- CLIENT_ID = ACME (example) ---

TENANT_ACME_KEY=acme_REPLACE_WITH_RANDOM_SECRET
TENANT_ACME_NAME=Acme Ltd
TENANT_ACME_FROM=Acme <hello@acme.com>
TENANT_ACME_REPLY_TO=hello@acme.com

# SMS (optional — remove if email only)
TENANT_ACME_SMS_SENDER=Acme
TENANT_ACME_NOTIFIER_KEY=paste-notifierbg-api-token-here

# =============================================================================
# CHECKLIST
# =============================================================================
# [ ] TENANT_*_KEY is unique per client (worker auth — site uses this)
# [ ] TENANT_*_FROM matches verified sender in ZeptoMail
# [ ] NOTIFIER_KEY is from Notifier.bg (only if SMS)
# [ ] Same vars in Vercel
# [ ] bun run seed
# [ ] Admin → Clients shows tenant + Notifier OK (if SMS)
# [ ] Site backend has NOTIFICATION_WORKER_API_KEY = TENANT_*_KEY
# =============================================================================
